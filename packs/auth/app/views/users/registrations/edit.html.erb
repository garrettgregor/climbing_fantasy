<div class="flex flex-col items-center justify-center min-h-screen px-4 py-12">
  <div class="text-center mb-8">
    <div class="flex items-center justify-center gap-3 mb-2">
      <%= image_tag("top_out_logo.png", alt: "TopOut", class: "h-12 w-12") %>
      <h1 class="text-3xl font-bold text-white">TopOut</h1>
    </div>
  </div>

  <div class="w-full max-w-md bg-gray-900 rounded-2xl p-8 border border-gray-800">
    <h2 class="text-2xl font-bold text-white mb-1">Edit Account</h2>
    <p class="text-gray-400 text-sm mb-6">Update your profile information</p>

    <%= render "users/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }, data: { controller: "availability-check", availability_check_url_value: user_registration_availability_path }) do |f| %>
      <div>
        <label for="user_display_name" class="block text-sm font-medium text-gray-300 mb-1.5">Display Name</label>
        <%= f.text_field :display_name, autocomplete: "nickname", data: { availability_check_target: "displayNameInput", action: "input->availability-check#check blur->availability-check#check" }, class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
        <p data-availability-check-target="displayNameStatus" class="mt-1 text-xs text-gray-500"></p>
      </div>

      <div>
        <label for="user_email" class="block text-sm font-medium text-gray-300 mb-1.5">Email</label>
        <%= f.email_field :email, autocomplete: "email", data: { availability_check_target: "emailInput", action: "input->availability-check#check blur->availability-check#check" }, class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
        <p data-availability-check-target="emailStatus" class="mt-1 text-xs text-gray-500"></p>
      </div>

      <div>
        <label for="user_password" class="block text-sm font-medium text-gray-300 mb-1.5">New Password</label>
        <p class="text-gray-500 text-xs mb-1">Leave blank if you don't want to change it</p>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
      </div>

      <div>
        <label for="user_password_confirmation" class="block text-sm font-medium text-gray-300 mb-1.5">Confirm New Password</label>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
      </div>

      <div>
        <label for="user_current_password" class="block text-sm font-medium text-gray-300 mb-1.5">Current Password</label>
        <p class="text-gray-500 text-xs mb-1">We need your current password to confirm changes</p>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
      </div>

      <div>
        <%= f.submit "Update Account", class: "w-full bg-accent hover:bg-accent-hover text-gray-900 font-semibold py-2.5 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <p class="text-center text-gray-400 text-sm mt-6">
      <%= link_to "Back to dashboard", authenticated_root_path, class: "text-accent hover:text-accent-hover font-semibold" %>
    </p>
  </div>
</div>
