<div class="flex flex-col items-center justify-center min-h-screen px-4 py-12">
  <%# Header %>
  <div class="text-center mb-8">
    <div class="flex items-center justify-center gap-3 mb-2">
      <%= image_tag("top_out_logo.png", alt: "TopOut", class: "h-12 w-12") %>
      <h1 class="text-3xl font-bold text-white">TopOut</h1>
    </div>
    <p class="text-gray-400 text-sm">Fantasy Climbing Draft Platform</p>
  </div>

  <%# Registration Card %>
  <div class="w-full max-w-md bg-gray-900 rounded-2xl p-8 border border-gray-800">
    <h2 class="text-2xl font-bold text-white mb-1">Create Account</h2>
    <p class="text-gray-400 text-sm mb-6">Join the climbing fantasy community</p>

    <%= render "users/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }, data: { controller: "availability-check", availability_check_url_value: user_registration_availability_path }) do |f| %>
      <div>
        <label for="user_display_name" class="block text-sm font-medium text-gray-300 mb-1.5">Display Name</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <%= f.text_field :display_name, autofocus: true, autocomplete: "nickname", placeholder: "Your display name", data: { availability_check_target: "displayNameInput", action: "input->availability-check#check blur->availability-check#check" }, class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 pl-10 pr-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
        </div>
        <p data-availability-check-target="displayNameStatus" class="mt-1 text-xs text-gray-500"></p>
      </div>

      <div>
        <label for="user_email" class="block text-sm font-medium text-gray-300 mb-1.5">Email</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com", data: { availability_check_target: "emailInput", action: "input->availability-check#check blur->availability-check#check" }, class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 pl-10 pr-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
        </div>
        <p data-availability-check-target="emailStatus" class="mt-1 text-xs text-gray-500"></p>
      </div>

      <div>
        <label for="user_password" class="block text-sm font-medium text-gray-300 mb-1.5">Password</label>
        <div class="relative" data-controller="password-visibility">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "At least 6 characters", data: { password_visibility_target: "input" }, class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 pl-10 pr-10 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
          <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-500 hover:text-gray-300">
            <svg data-password-visibility-target="showIcon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <svg data-password-visibility-target="hideIcon" class="h-5 w-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
            </svg>
          </button>
        </div>
      </div>

      <div>
        <label for="user_password_confirmation" class="block text-sm font-medium text-gray-300 mb-1.5">Confirm Password</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm your password", class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 pl-10 pr-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
        </div>
      </div>

      <div>
        <%= f.submit "Create Account", class: "w-full bg-accent hover:bg-accent-hover text-gray-900 font-semibold py-2.5 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <p class="text-center text-gray-400 text-sm mt-6">
      Already have an account?
      <%= link_to "Sign in", new_session_path(resource_name), class: "text-accent hover:text-accent-hover font-semibold" %>
    </p>
  </div>
</div>
