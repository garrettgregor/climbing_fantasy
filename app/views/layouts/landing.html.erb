<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <title><%= content_for(:title) || "Top Out Fantasy League | Reach the Peak" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="The world's premier fantasy climbing experience. Build your elite squad, compete head-to-head, and dominate the vertical world.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/top_out_favicon.png" type="image/png">
    <link rel="shortcut icon" href="/top_out_favicon.png" type="image/png">
    <link rel="apple-touch-icon" href="/top_out_favicon.png">

    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-display bg-background-dark text-slate-100 antialiased overflow-x-hidden">
    <%= yield %>
  </body>
</html>
